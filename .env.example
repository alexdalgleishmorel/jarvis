# Copy to .env and fill in. Consumed by the conductor container (docker-compose).
# All conductor settings are JARVIS_*-prefixed.
#
# IMPORTANT (README §8): do NOT put ANTHROPIC_API_KEY here. With subscription
# billing the conductor fails to start if it sees one, so the brain can't
# silently bill the per-token API account.

# Home Assistant long-lived access token (Profile → Security → Long-lived tokens).
JARVIS_HA_TOKEN=

# Brain: "echo" (tokenless, default) or "claude" once §8 billing is confirmed.
# JARVIS_BRAIN_MODE=echo
# JARVIS_BILLING_MODE=subscription
# JARVIS_QUICK_MODEL=

# Voice: "null" (HA pipeline speaks, default) or "ha_piper" (conductor speaks).
# JARVIS_TTS_MODE=null
# JARVIS_TTS_ENTITY_ID=tts.piper

# Conductor behaviour.
# JARVIS_DEFAULT_AREA=home
# JARVIS_SESSION_IDLE_TIMEOUT_S=300
# JARVIS_LOG_LEVEL=INFO
